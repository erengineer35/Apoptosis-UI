<Window x:Class="ApoptosisUI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cell Morphology Studio - Login"
        Height="700"
        Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F8F6F9"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="14 12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1CCD6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#322935"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InputPasswordBox" TargetType="PasswordBox">
            <Setter Property="Padding" Value="14 12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1CCD6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#322935"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#6B4E71"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20 14"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#7D5E84"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#5A4260"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#BDB2C4"/>
            <Setter Property="Foreground" Value="#322935"/>
            <Setter Property="Padding" Value="20 14"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#CCC3D0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#A89DB0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6B4E71"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="text"
                                   Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   TextDecorations="Underline"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="text" Property="Foreground" Value="#9F7B7B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="White"
                CornerRadius="24"
                Margin="24"
                Padding="32">
            <Border.Effect>
                <DropShadowEffect Color="#BDB2C4" BlurRadius="30" ShadowDepth="0" Opacity="0.4"/>
            </Border.Effect>

            <StackPanel VerticalAlignment="Center">
                <!-- Logo/Title -->
                <TextBlock Text="Cell Morphology"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#322935"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Studio"
                           FontSize="28"
                           FontWeight="Light"
                           Foreground="#6B4E71"
                           HorizontalAlignment="Center"
                           Margin="0 0 0 8"/>
                <TextBlock Text="Apoptosis Detection System"
                           FontSize="12"
                           Foreground="#5E5461"
                           HorizontalAlignment="Center"
                           Margin="0 0 0 32"/>

                <!-- Login Form -->
                <Grid x:Name="LoginForm">
                    <StackPanel>
                        <TextBlock Text="Username"
                                   Foreground="#5E5461"
                                   FontSize="12"
                                   Margin="4 0 0 6"/>
                        <TextBox x:Name="UsernameBox"
                                 Style="{StaticResource InputTextBox}"
                                 Margin="0 0 0 16"/>

                        <TextBlock Text="Password"
                                   Foreground="#5E5461"
                                   FontSize="12"
                                   Margin="4 0 0 6"/>
                        <PasswordBox x:Name="PasswordBox"
                                     Style="{StaticResource InputPasswordBox}"
                                     Margin="0 0 0 8"/>

                        <TextBlock x:Name="ErrorText"
                                   Text=""
                                   Foreground="#EF4444"
                                   FontSize="12"
                                   Margin="4 0 0 16"
                                   Visibility="Collapsed"/>

                        <Button Content="Login"
                                Style="{StaticResource PrimaryButton}"
                                Click="LoginButton_Click"
                                Margin="0 8 0 12"/>

                        <Button Content="Continue as Guest"
                                Style="{StaticResource SecondaryButton}"
                                Click="GuestButton_Click"
                                Margin="0 0 0 20"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="Don't have an account? "
                                       Foreground="#5E5461"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                            <Button Content="Register"
                                    Style="{StaticResource LinkButton}"
                                    Click="ShowRegisterButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Register Form -->
                <Grid x:Name="RegisterForm" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Username"
                                   Foreground="#5E5461"
                                   FontSize="12"
                                   Margin="4 0 0 6"/>
                        <TextBox x:Name="RegUsernameBox"
                                 Style="{StaticResource InputTextBox}"
                                 Margin="0 0 0 16"/>

                        <TextBlock Text="Password"
                                   Foreground="#5E5461"
                                   FontSize="12"
                                   Margin="4 0 0 6"/>
                        <PasswordBox x:Name="RegPasswordBox"
                                     Style="{StaticResource InputPasswordBox}"
                                     Margin="0 0 0 16"/>

                        <TextBlock Text="Confirm Password"
                                   Foreground="#5E5461"
                                   FontSize="12"
                                   Margin="4 0 0 6"/>
                        <PasswordBox x:Name="RegConfirmPasswordBox"
                                     Style="{StaticResource InputPasswordBox}"
                                     Margin="0 0 0 8"/>

                        <TextBlock x:Name="RegErrorText"
                                   Text=""
                                   Foreground="#EF4444"
                                   FontSize="12"
                                   Margin="4 0 0 16"
                                   Visibility="Collapsed"/>

                        <Button Content="Create Account"
                                Style="{StaticResource PrimaryButton}"
                                Click="RegisterButton_Click"
                                Margin="0 8 0 20"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="Already have an account? "
                                       Foreground="#5E5461"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                            <Button Content="Login"
                                    Style="{StaticResource LinkButton}"
                                    Click="ShowLoginButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
